<view class="app"><view class="hero-section"><view class="hero-bg"></view><view class="hero-content"><view class="app-logo"><text class="logo-icon">📅</text></view><view class="app-title">时光记</view><view class="app-slogan">记住每一个重要日子</view><view class="time-display"><view class="time-main"><text class="time-date">{{a}}</text><text class="time-separator">|</text><text class="time-clock">{{b}}</text></view><text class="time-lunar">{{c}}</text></view></view><view class="hero-decoration"><view class="deco-circle deco-1"></view><view class="deco-circle deco-2"></view><view class="deco-circle deco-3"></view></view></view><view class="main-content"><view class="upcoming-section card"><view class="section-header"><view class="section-title-wrap"><text class="section-icon">🎁</text><text class="section-title">即将到来</text><text wx:if="{{d}}" class="record-count">{{e}}个</text></view></view><view wx:if="{{f}}" class="upcoming-list"><view wx:for="{{g}}" wx:for-item="item" wx:key="i" class="upcoming-item" bindtap="{{item.j}}"><view class="{{['days-circle', item.b && 'today']}}"><text class="days-num">{{item.a}}</text><text class="days-text">天</text></view><view class="upcoming-name">{{item.c}}</view><view class="upcoming-date"><text wx:if="{{item.d}}" class="lunar-badge">农历</text> {{item.e}}</view><view wx:if="{{item.f}}" class="upcoming-age">{{item.g}}岁</view><view class="{{['group-dot', item.h]}}"></view></view></view><view wx:else class="empty-upcoming"><text class="empty-icon">🌸</text><text class="empty-text">暂无即将到来的日子</text></view></view><view class="records-section card"><view class="section-header"><view class="section-title-wrap"><text class="section-icon">📒</text><text class="section-title">我的记录</text><text class="record-count">{{h}}条</text></view></view><scroll-view scroll-x class="filter-scroll"><view class="filter-tabs"><view wx:for="{{i}}" wx:for-item="tab" wx:key="c" class="{{['filter-tab', tab.d]}}" bindtap="{{tab.e}}"><text class="tab-icon">{{tab.a}}</text><text class="tab-text">{{tab.b}}</text></view></view></scroll-view><view class="record-list"><view wx:for="{{j}}" wx:for-item="record" wx:key="j" class="record-card" bindtap="{{record.k}}"><view class="record-left"><view class="{{['record-avatar', record.b]}}">{{record.a}}</view></view><view class="record-body"><view class="record-header"><text class="record-name">{{record.c}}</text><view class="{{['tag', record.e]}}">{{record.d}}</view></view><view class="record-date-row"><view class="date-main"><text wx:if="{{record.f}}" class="lunar-badge small">农历</text> {{record.g}}</view><text wx:if="{{record.h}}" class="age-badge">{{record.i}}岁</text></view></view></view><view wx:if="{{k}}" class="empty-state"><text class="empty-icon">📝</text><text class="empty-main">暂无记录</text><text class="empty-hint">点击右上角"添加"来创建第一条记录</text></view></view></view></view></view>