
.page.data-v-602d3812 {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8F9 0%, #FFF0F5 100%);
}

/* 顶部导航 */
.header-bar.data-v-602d3812 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #FF9A8B 0%, #FF6A88 100%);
  padding: 60rpx 32rpx 32rpx;
  color: white;
}
.back-btn.data-v-602d3812 {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-icon.data-v-602d3812 {
  font-size: 48rpx;
  font-weight: bold;
  line-height: 1;
}
.header-title.data-v-602d3812 {
  font-size: 34rpx;
  font-weight: 600;
}
.header-placeholder.data-v-602d3812 {
  width: 64rpx;
}

/* 模式切换 */
.mode-tabs.data-v-602d3812 {
  display: flex;
  gap: 14rpx;
  padding: 20rpx 24rpx;
  background: white;
  border-bottom: 1rpx solid #FFE4E8;
}
.mode-tab.data-v-602d3812 {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: #FFF5F7;
  color: #A0522D;
  font-size: 26rpx;
  transition: all 0.3s ease;
}
.mode-tab.active.data-v-602d3812 {
  background: linear-gradient(135deg, #FFB6C1, #FFC0CB);
  color: #8B4513;
  box-shadow: 0 4rpx 12rpx rgba(255, 183, 193, 0.4);
}
.tab-icon.data-v-602d3812 {
  font-size: 28rpx;
}

/* 表单内容 */
.form-content.data-v-602d3812 {
  padding: 28rpx;
}

/* 表单卡片 */
.form-card.data-v-602d3812 {
  background: white;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}
.card-title.data-v-602d3812 {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 28rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #FFF5F3;
}
.title-icon.data-v-602d3812 {
  font-size: 32rpx;
}

/* 提示信息 */
.tips-section.data-v-602d3812 {
  background: #FFF9F7;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}
.tips-item.data-v-602d3812 {
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
}

/* 表单项 */
.form-section.data-v-602d3812 {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F8F8F8;
}
.form-section.data-v-602d3812:last-child {
  border-bottom: none;
  padding-bottom: 0;
}
.section-icon.data-v-602d3812 {
  font-size: 32rpx;
  margin-right: 16rpx;
  margin-top: 2rpx;
}
.section-body.data-v-602d3812 {
  flex: 1;
}
.form-label.data-v-602d3812 {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}
.label-hint.data-v-602d3812 {
  font-size: 22rpx;
  color: #CCC;
}
.picker-value.data-v-602d3812 {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  display: flex;
  align-items: center;
}
.picker-arrow.data-v-602d3812 {
  margin-left: auto;
  font-size: 32rpx;
  color: #CCC;
}
.input.data-v-602d3812 {
  font-size: 30rpx;
  color: #333;
  padding: 4rpx 0;
}

/* 日期行 */
.form-row.data-v-602d3812 {
  display: flex;
  gap: 20rpx;
}
.form-section.half.data-v-602d3812 {
  flex: 1;
}

/* 文本输入 */
.text-section.data-v-602d3812 {
  padding: 20rpx 0;
}
.text-input.data-v-602d3812 {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
}

/* 预览 */
.preview-section.data-v-602d3812 {
  background: #FFF9F7;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}
.preview-title.data-v-602d3812 {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}
.preview-item.data-v-602d3812 {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #FFE8E3;
}
.preview-item.data-v-602d3812:last-child {
  border-bottom: none;
}
.preview-date.data-v-602d3812 {
  width: 140rpx;
  font-size: 24rpx;
  color: #FF6A88;
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.lunar-tag.data-v-602d3812 {
  background: #FFB7C5;
  color: white;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  font-size: 18rpx;
}
.preview-name.data-v-602d3812 {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}
.preview-group.data-v-602d3812 {
  font-size: 22rpx;
  color: #999;
}

/* 按钮 */
.btn-import.data-v-602d3812, .btn-save.data-v-602d3812 {
  width: 100%;
  background: linear-gradient(135deg, #FFB6C1, #FFC0CB);
  color: #8B4513;
  border-radius: 36rpx;
  padding: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  margin-top: 24rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(255, 183, 193, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}
.btn-import.data-v-602d3812:active, .btn-save.data-v-602d3812:active {
  opacity: 0.9;
}
.btn-icon.data-v-602d3812 {
  font-size: 26rpx;
}
